# Edge Function secrets. Set with: supabase secrets set --env-file supabase/.env
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically in prod.)

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis Stack (RediSearch required for VSS). Use rediss:// for TLS.
REDIS_URL=redis://localhost:6379

# Model / API providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
LETTA_API_KEY=
RESEND_API_KEY=

# Shared secrets for webhook / cron authentication
AGENT_SYNC_SECRET=
CRON_SECRET=

# Public web app URL (used in invite links)
APP_URL=http://localhost:3000

# Arize Phoenix tracing (optional). Leave unset to disable tracing.
PHOENIX_OTLP_ENDPOINT=
PHOENIX_API_KEY=

# Pipeline tuning (optional — defaults live in _shared/pipeline_config.ts).
# Retrieval: candidates per branch, seeds kept after fusion, subgraph cap.
# RETRIEVAL_CANDIDATES=20
# RETRIEVAL_TOP_K=12
# RETRIEVAL_SUBGRAPH_MAX=40
# Hybrid fusion weights (vector vs. keyword) + Ebbinghaus recency decay.
# FUSION_VECTOR_WEIGHT=0.6
# FUSION_KEYWORD_WEIGHT=0.4
# RECENCY_HALF_LIFE_HOURS=72
# RECENCY_DECAY_FLOOR=0.3
# RELEVANCE_FLOOR=0.05
# Ingestion dedup window (minutes) + cross-person connection thresholds.
# INGEST_DEDUPE_WINDOW_MIN=5
# CONNECTION_SIMILARITY_THRESHOLD=0.82
# CONNECTION_MAX_PAIRS=50
