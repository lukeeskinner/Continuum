# Edge Function secrets. Set with: supabase secrets set --env-file supabase/.env
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically in prod.)

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis Stack (RediSearch required for VSS). Use rediss:// for TLS.
REDIS_URL=redis://localhost:6379

# Model / API providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
LETTA_API_KEY=
RESEND_API_KEY=

# Shared secrets for webhook / cron authentication
AGENT_SYNC_SECRET=
CRON_SECRET=

# Public web app URL (used in invite links)
APP_URL=http://localhost:3000
