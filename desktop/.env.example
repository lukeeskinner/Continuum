# Continuum desktop agent configuration. Copy to desktop/.env.

# Letta Cloud
LETTA_API_KEY=
LETTA_BASE_URL=https://api.letta.com
# Fallback agent id for headless use; normally resolved from the signed-in
# user's Supabase profile after login.
LETTA_AGENT_ID=

# Anthropic Claude vision sidecar. CONTINUUM_MODEL overrides the default
# claude-haiku-4-5 model used by sidecar/sidecar.py.
ANTHROPIC_API_KEY=
CONTINUUM_MODEL=claude-haiku-4-5-20251001

# Supabase (sign-in + identity resolution)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Identity fallback (normally resolved from the signed-in user's profile /
# cluster membership). Leave blank when signing in through the app.
CONTINUUM_USER_ID=
CONTINUUM_CLUSTER_ID=

# Supabase Edge Functions base URL (e.g. https://<ref>.supabase.co/functions/v1)
# and the agent-sync shared secret (must match the AGENT_SYNC_SECRET set on the
# Supabase functions). Used to push SHARED_ANON observations into the graph.
SUPABASE_FUNCTIONS_URL=
AGENT_SYNC_SECRET=

# Browserbase enrichment opt-in: comma-separated domain allowlist (empty = off).
BROWSERBASE_DOMAINS=arxiv.org,github.com

# Privacy: extra macOS bundle ids to hard-block, merged with the built-in
# defaults (1Password, Messages, WhatsApp, Signal, …). Comma-separated.
# PRIVACY_BLOCK_BUNDLES=

# Global shortcut that toggles the query (Spotlight-style) command bar.
# QUERY_SHORTCUT=CommandOrControl+Shift+Space

# Sentry error monitoring (optional; disabled when SENTRY_DSN is unset).
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# Orkes Conductor workflow orchestration (optional). When set, SHARED_ANON
# observations are ingested via a durable Conductor workflow.
# ORKES_SERVER_URL=https://developer.orkescloud.com
# ORKES_KEY_ID=
# ORKES_KEY_SECRET=

# Capture tuning
CAPTURE_INTERVAL_MS=4000
# Adaptive sampling: once idle past IDLE_PAUSE_SECONDS the interval stretches
# toward IDLE_CAPTURE_INTERVAL_MS; past DEEP_IDLE_SECONDS we stop capturing and
# only light-poll (DEEP_IDLE_POLL_MS) for the user's return.
IDLE_CAPTURE_INTERVAL_MS=16000
IDLE_PAUSE_SECONDS=30
DEEP_IDLE_SECONDS=300
DEEP_IDLE_POLL_MS=5000
# Exponential backoff cap (ms) after consecutive pipeline errors.
MAX_BACKOFF_MS=60000
# Perceptual-hash Hamming distance at/below which two frames count as identical.
HASH_HAMMING_THRESHOLD=6
# Semantic dedup: skip identical descriptors within this window (ms), but force
# one through every SEMANTIC_FORCE_REFRESH_MS so long contexts still refresh.
SEMANTIC_DEDUP_WINDOW_MS=60000
SEMANTIC_FORCE_REFRESH_MS=120000

# Vision sidecar (Claude) — REQUIRED. The Python sidecar (sidecar/sidecar.py)
# sends screenshots to Anthropic Claude vision to extract observations; without
# this key the sidecar emits empty descriptors.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-haiku-4-5).
CONTINUUM_MODEL=

# Python sidecar
PYTHON_PATH=python3
SIDECAR_SCRIPT=sidecar/sidecar.py
